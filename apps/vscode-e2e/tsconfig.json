{
	"extends": "@njust-ai/config-typescript/base.json",
	"compilerOptions": {
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "ESNext.Disposable", "DOM"],
		"sourceMap": true,
		"useUnknownInCatchVariables": false,
		"rootDir": "../..",
		"outDir": "out"
	},
	"include": ["src"],
	"exclude": [".vscode-test", "**/node_modules/**", "out"]
}
