{
	"name": "@njust-ai/cli",
	"version": "0.1.17",
	"description": "NJUST_AI CLI - Run the NJUST_AI agent from the command line",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"njust-ai": "dist/index.js"
	},
	"scripts": {
		"format": "prettier --write 'src/**/*.ts'",
		"lint": "eslint src --ext .ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "tsx scripts/integration/run.ts",
		"build": "tsup",
		"build:extension": "pnpm --filter njust-ai bundle",
		"dev": "tsx src/index.ts",
		"dev:local": "NJUST_AI_AUTH_BASE_URL=http://localhost:3000 NJUST_AI_SDK_BASE_URL=http://localhost:3001 NJUST_AI_PROVIDER_URL=http://localhost:8080/proxy tsx src/index.ts",
		"clean": "rimraf dist .turbo"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"@njust-ai/core": "workspace:^",
		"@njust-ai/types": "workspace:^",
		"@njust-ai/vscode-shim": "workspace:^",
		"@trpc/client": "^11.8.1",
		"@vscode/ripgrep": "^1.15.9",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"execa": "^9.5.2",
		"fuzzysort": "^3.1.0",
		"ink": "^6.6.0",
		"p-wait-for": "^5.0.2",
		"react": "^19.1.0",
		"superjson": "^2.2.6",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@njust-ai/config-eslint": "workspace:^",
		"@njust-ai/config-typescript": "workspace:^",
		"@types/node": "20.x",
		"@types/react": "^19.1.6",
		"ink-testing-library": "^4.0.0",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"vitest": "^3.2.3"
	}
}
