{
  "name": "njust-ai-cj",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": "20.19.2"
  },
  "scripts": {
    "preinstall": "node scripts/bootstrap.mjs",
    "prepare": "",
    "install": "node scripts/bootstrap.mjs",
    "install:all": "node scripts/bootstrap.mjs",
    "lint": "turbo lint --log-order grouped --output-logs new-only",
    "check-types": "turbo check-types --log-order grouped --output-logs new-only",
    "test": "turbo test --log-order grouped --output-logs new-only",
    "test:coverage": "pnpm exec vitest run --coverage --config src/vitest.config.ts",
    "format": "turbo format --log-order grouped --output-logs new-only",
    "build": "turbo build --log-order grouped --output-logs new-only",
    "bundle": "turbo bundle --log-order grouped --output-logs new-only",
    "bundle:nightly": "turbo bundle:nightly --log-order grouped --output-logs new-only",
    "vsix": "turbo vsix --log-order grouped --output-logs new-only",
    "vsix:nightly": "turbo vsix:nightly --log-order grouped --output-logs new-only",
    "clean": "turbo clean --log-order grouped --output-logs new-only && rimraf dist out bin .vite-port .turbo",
    "install:vsix": "pnpm install --frozen-lockfile && pnpm clean && pnpm vsix && node scripts/install-vsix.js",
    "install:vsix:nightly": "pnpm install --frozen-lockfile && pnpm clean && pnpm vsix:nightly && node scripts/install-vsix.js --nightly",
    "code-server:install": "node scripts/code-server.js",
    "changeset:version": "cp CHANGELOG.md src/CHANGELOG.md && changeset version && cp -vf src/CHANGELOG.md .",
    "knip": "knip --include files",
    "syncpack:lint": "node scripts/check-repo-hygiene.mjs && syncpack lint-semver-ranges",
    "syncpack:report": "syncpack list-mismatches",
    "check-secrets": "git diff --cached --name-only 2>/dev/null | node scripts/check-secrets.mjs || node scripts/check-secrets.mjs --all-files",
    "evals": "dotenvx run -f packages/evals/.env.development packages/evals/.env.local -- docker compose -f packages/evals/docker-compose.yml --profile server --profile runner up --build --scale runner=0",
    "npm:publish:types": "pnpm --filter @njust-ai-cj/types npm:publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@dotenvx/dotenvx": "^1.34.0",
    "@njust-ai-cj/config-typescript": "workspace:^",
    "@types/glob": "^9.0.0",
    "@types/node": "20.x",
    "@vitest/coverage-v8": "^3.2.3",
    "@vscode/vsce": "3.3.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.28.0",
    "glob": "^11.1.0",
    "knip": "^5.44.4",
    "mkdirp": "^3.0.1",
    "only-allow": "^1.2.1",
    "ovsx": "0.10.4",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "syncpack": "13",
    "tsx": "^4.19.3",
    "turbo": "^2.5.6",
    "typescript": "5.8.3",
    "vitest": "^3.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/ripgrep"
    ],
    "overrides": {
      "tar-fs": ">=3.1.1",
      "tar": ">=7.5.15",
      "esbuild": ">=0.25.0",
      "undici": ">=6.24.0",
      "axios": ">=1.15.2",
      "vite": "6.4.2",
      "rollup": ">=4.60.4",
      "next": ">=16.2.6",
      "drizzle-orm": ">=0.45.2",
      "jws": ">=4.0.1",
      "@eslint/plugin-kit": ">=0.3.4",
      "tmp": ">=0.2.4",
      "diff": ">=5.2.2",
      "dompurify": ">=3.4.3",
      "flatted": ">=3.4.2",
      "serialize-javascript": ">=7.0.3",
      "path-to-regexp": ">=8.4.2",
      "@xmldom/xmldom": ">=0.8.13",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1",
      "underscore": ">=1.13.8",
      "mdast-util-to-hast": ">=13.2.1",
      "markdown-it": ">=14.1.1",
      "ajv": ">=6.14.0",
      "qs": ">=6.14.1",
      "follow-redirects": ">=1.16.0",
      "postcss": ">=8.5.10",
      "@changesets/parse>js-yaml": ">=4.1.1",
      "read-yaml-file>js-yaml": ">=4.1.1",
      "@eslint/eslintrc>js-yaml": ">=4.1.1",
      "gray-matter>js-yaml": "3.14.2",
      "knip>js-yaml": ">=4.1.1",
      "cosmiconfig>js-yaml": ">=4.1.1",
      "mocha>js-yaml": ">=4.1.1",
      "@isaacs/brace-expansion": ">=5.0.1",
      "@eslint/config-array>minimatch": ">=3.1.4",
      "@eslint/eslintrc>minimatch": ">=3.1.4",
      "eslint>minimatch": ">=3.1.4",
      "eslint-plugin-react>minimatch": ">=3.1.4",
      "copyfiles>minimatch": ">=3.1.4",
      "vscode-languageclient>minimatch": ">=5.1.8",
      "@typescript-eslint/typescript-estree>minimatch": ">=9.0.7",
      "test-exclude>minimatch": ">=3.1.4",
      "readdir-glob>minimatch": ">=5.1.8",
      "@vscode/test-cli>minimatch": ">=9.0.7",
      "@vscode/vsce>minimatch": ">=3.1.4",
      "mocha>minimatch": ">=5.1.8",
      "syncpack>minimatch": ">=9.0.7",
      "glob>minimatch": ">=10.2.5",
      "npm-run-all2>minimatch": ">=10.2.5",
      "anymatch@3.1.3>picomatch": ">=2.3.2",
      "readdirp>picomatch": ">=2.3.2",
      "jest-util>picomatch": ">=2.3.2",
      "micromatch@4.0.8>picomatch": ">=4.0.4",
      "knip>picomatch": ">=4.0.4",
      "vitest>picomatch": ">=4.0.4",
      "tinyglobby>picomatch": ">=4.0.4",
      "@dotenvx/dotenvx@1.44.2>picomatch": ">=4.0.4",
      "minimatch@3.1.2>brace-expansion": "^1.1.14",
      "minimatch@9.0.5>brace-expansion": "^2.1.0",
      "minimatch@10.2.5>brace-expansion": "^5.0.6",
      "form-data": ">=4.0.4",
      "bluebird": ">=3.7.2",
      "glob": ">=11.1.0",
      "protobufjs": ">=7.5.8",
      "@types/react": "^18.3.23",
      "@types/react-dom": "^18.3.5",
      "zod": "3.25.76"
    }
  }
}
