{
	"name": "njust-ai",
	"version": "2026.6.1",
	"description": "AI-powered coding assistant for NJUST",
	"main": "./dist/extension.js",
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=50",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"format": "prettier --write .",
		"bundle": "node esbuild.mjs",
		"sync:bundled-cangjie-corpus": "node scripts/sync-bundled-cangjie-corpus.mjs",
		"vscode:prepublish": "pnpm sync:bundled-cangjie-corpus && pnpm bundle --production",
		"vsix": "mkdirp ../bin && vsce package --no-dependencies --out ../bin",
		"publish:marketplace": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"watch:bundle": "pnpm bundle --watch",
		"watch:tsc": "cd .. && tsc --noEmit --watch --project src/tsconfig.json",
		"clean": "rimraf README.md CHANGELOG.md LICENSE dist logs mock .turbo"
	},
	"dependencies": {
		"@ai-sdk/amazon-bedrock": "^4.0.51",
		"@ai-sdk/baseten": "^1.0.31",
		"@ai-sdk/deepseek": "^2.0.18",
		"@ai-sdk/fireworks": "^2.0.32",
		"@ai-sdk/google": "^3.0.22",
		"@ai-sdk/google-vertex": "^4.0.45",
		"@ai-sdk/mistral": "^3.0.19",
		"@ai-sdk/xai": "^3.0.48",
		"@anthropic-ai/sdk": "^0.37.0",
		"@anthropic-ai/vertex-sdk": "^0.7.0",
		"@aws-sdk/client-bedrock-runtime": "^3.1047.0",
		"@aws-sdk/credential-providers": "^3.1047.0",
		"@google/genai": "^1.29.1",
		"@lmstudio/sdk": "^1.1.1",
		"@mistralai/mistralai": "^1.9.18",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@njust-ai/core": "workspace:^",
		"@njust-ai/ipc": "workspace:^",
		"@njust-ai/prompt-engine": "workspace:^",
		"@njust-ai/telemetry": "workspace:^",
		"@njust-ai/types": "workspace:^",
		"@qdrant/js-client-rest": "^1.14.0",
		"@vscode/codicons": "^0.0.36",
		"async-mutex": "^0.5.0",
		"axios": "^1.15.2",
		"cheerio": "^1.0.0",
		"chokidar": "^4.0.1",
		"clone-deep": "^4.0.1",
		"default-shell": "^2.2.0",
		"delay": "^6.0.0",
		"diff": "^5.2.2",
		"exceljs": "^4.4.0",
		"fast-deep-equal": "^3.1.3",
		"fastest-levenshtein": "^1.0.16",
		"fzf": "^0.5.2",
		"get-folder-size": "^5.0.0",
		"global-agent": "^3.0.0",
		"google-auth-library": "^9.15.1",
		"gray-matter": "^4.0.3",
		"i18next": "^25.0.0",
		"ignore": "^7.0.3",
		"isbinaryfile": "^5.0.2",
		"json-stream-stringify": "^3.1.6",
		"lodash.debounce": "^4.0.8",
		"mammoth": "^1.11.0",
		"monaco-vscode-textmate-theme-converter": "^0.1.7",
		"node-cache": "^5.1.2",
		"node-ipc": "^12.0.0",
		"ollama": "^0.5.17",
		"openai": "^5.12.2",
		"os-name": "^6.0.0",
		"p-limit": "^6.2.0",
		"p-wait-for": "^5.0.2",
		"partial-json": "^0.1.7",
		"pdf-parse": "^1.1.1",
		"pretty-bytes": "^7.0.0",
		"proper-lockfile": "^4.1.2",
		"reconnecting-eventsource": "^1.6.4",
		"safe-stable-stringify": "^2.5.0",
		"sambanova-ai-provider": "^1.2.2",
		"sanitize-filename": "^1.6.3",
		"say": "^0.16.0",
		"semver-compare": "^1.0.0",
		"serialize-error": "^12.0.0",
		"shell-quote": "^1.8.2",
		"simple-git": "^3.36.0",
		"smol-toml": "^1.6.1",
		"sound-play": "^1.1.0",
		"strip-ansi": "^7.1.0",
		"strip-bom": "^5.0.0",
		"tiktoken": "^1.0.21",
		"tree-sitter-wasms": "^0.1.12",
		"turndown": "^7.2.0",
		"undici": "^7.24.0",
		"uuid": "^11.1.1",
		"vscode-languageclient": "^9.0.1",
		"vscode-material-icons": "^0.1.1",
		"web-tree-sitter": "^0.25.6",
		"workerpool": "^9.2.0",
		"yaml": "^2.8.3",
		"zhipu-ai-provider": "^0.2.2",
		"zod": "^3.25.76",
		"zod-to-json-schema": "^3.24.5"
	},
	"devDependencies": {
		"@ai-sdk/openai-compatible": "^2.0.28",
		"@njust-ai/build": "workspace:^",
		"@njust-ai/config-eslint": "workspace:^",
		"@njust-ai/config-typescript": "workspace:^",
		"@openrouter/ai-sdk-provider": "^2.1.1",
		"@types/clone-deep": "^4.0.4",
		"@types/debug": "^4.1.12",
		"@types/diff": "^5.2.1",
		"@types/glob": "^8.1.0",
		"@types/lodash.debounce": "^4.0.9",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.0",
		"@types/node-cache": "^4.1.3",
		"@types/node-ipc": "^9.2.3",
		"@types/proper-lockfile": "^4.1.4",
		"@types/semver-compare": "^1.0.3",
		"@types/shell-quote": "^1.7.5",
		"@types/turndown": "^5.0.5",
		"@types/vscode": "^1.93.0",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.3.2",
		"ai": "^6.0.75",
		"esbuild-wasm": "^0.25.0",
		"execa": "^9.5.2",
		"glob": "^11.1.0",
		"mkdirp": "^3.0.1",
		"nock": "^14.0.4",
		"npm-run-all2": "^8.0.1",
		"ovsx": "^0.10.4",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"vitest": "^4.1.8",
		"zod-to-ts": "^1.2.0"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"author": {
		"name": "NJUST_AI"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"contributes": {
		"languages": [
			{
				"id": "cangjie",
				"aliases": [
					"Cangjie",
					"仓颉",
					"cj"
				],
				"extensions": [
					".cj"
				],
				"configuration": "./languages/cangjie-language-configuration.json"
			},
			{
				"id": "matlab",
				"aliases": [
					"Matlab",
					"MATLAB",
					"Octave"
				],
				"extensions": [
					".m",
					".mlx"
				],
				"configuration": "./languages/matlab-language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "cangjie",
				"scopeName": "source.cangjie",
				"path": "./syntaxes/cangjie.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "cangjie",
				"path": "./snippets/cangjie.json"
			}
		],
		"taskDefinitions": [
			{
				"type": "cjpm",
				"required": [
					"command"
				],
				"properties": {
					"command": {
						"type": "string",
						"description": "The cjpm subcommand to run (build, run, test, bench, clean, check, init, update, tree)"
					},
					"args": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "Additional arguments for the cjpm command"
					}
				}
			}
		],
		"problemMatchers": [
			{
				"name": "cjc",
				"owner": "cangjie",
				"fileLocation": [
					"relative",
					"${workspaceFolder}"
				],
				"pattern": [
					{
						"regexp": "^(error|warning):\\s+(.+)$",
						"severity": 1,
						"message": 2
					},
					{
						"regexp": "^\\s+==>\\s+(.+?):(\\d+):(\\d+):$",
						"file": 1,
						"line": 2,
						"column": 3
					}
				]
			}
		],
		"debuggers": [
			{
				"type": "cangjie",
				"label": "Cangjie Debug",
				"languages": [
					"cangjie"
				],
				"configurationAttributes": {
					"launch": {
						"required": [
							"program"
						],
						"properties": {
							"program": {
								"type": "string",
								"description": "可执行文件路径（cjpm build 输出）",
								"default": "${workspaceFolder}/target/output"
							},
							"args": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "程序运行参数",
								"default": []
							},
							"cwd": {
								"type": "string",
								"description": "工作目录",
								"default": "${workspaceFolder}"
							},
							"debuggerArgs": {
								"type": "array",
								"items": {
									"type": "string"
								},
								"description": "传递给 cjdb 的额外参数",
								"default": []
							}
						}
					}
				},
				"configurationSnippets": [
					{
						"label": "Cangjie: 调试程序",
						"description": "构建并调试仓颉程序",
						"body": {
							"type": "cangjie",
							"request": "launch",
							"name": "调试仓颉程序",
							"program": "^\"\\${workspaceFolder}/target/output\"",
							"args": [],
							"cwd": "^\"\\${workspaceFolder}\"",
							"preLaunchTask": "cjpm: build"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "njust-ai-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"njust-ai-ActivityBar": [
				{
					"icon": "assets/icons/icon.svg",
					"type": "webview",
					"id": "njust-ai.SidebarProvider",
					"name": "%views.sidebar.name%"
				}
			]
		},
		"commands": [
			{
				"command": "njust-ai.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(edit)"
			},
			{
				"command": "njust-ai.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "njust-ai.popoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "njust-ai.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "njust-ai.openInNewTab",
				"title": "%command.openInNewTab.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.terminalAddToContext",
				"title": "%command.terminal.addToContext.title%",
				"category": "Terminal"
			},
			{
				"command": "njust-ai.terminalFixCommand",
				"title": "%command.terminal.fixCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "njust-ai.terminalExplainCommand",
				"title": "%command.terminal.explainCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "njust-ai.setCustomStoragePath",
				"title": "%command.setCustomStoragePath.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.importSettings",
				"title": "%command.importSettings.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.focusInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.toggleAutoApprove",
				"title": "%command.toggleAutoApprove.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.runCode",
				"title": "%command.runCode.title%",
				"icon": "$(play)",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.openMarkdownPreview",
				"title": "%command.openMarkdownPreview.title%",
				"icon": "$(open-preview)",
				"category": "%configuration.title%"
			},
			{
				"command": "njust-ai.latexCompile",
				"title": "%command.latexCompile.title%",
				"icon": "$(output)",
				"category": "LaTeX"
			},
			{
				"command": "njust-ai.cangjieBuild",
				"title": "Cangjie: Build (cjpm build)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieRun",
				"title": "Cangjie: Run (cjpm run)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieTest",
				"title": "Cangjie: Test (cjpm test)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieCheck",
				"title": "Cangjie: Check (cjpm check)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieClean",
				"title": "Cangjie: Clean (cjpm clean)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieVerifySdk",
				"title": "Cangjie: Verify SDK Installation",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieRestartLsp",
				"title": "Cangjie: Restart Language Server",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieRunTest",
				"title": "Cangjie: Run Test",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieDebugTest",
				"title": "Cangjie: Debug Test",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieInsertTemplate",
				"title": "Cangjie: Insert Template",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieProfile",
				"title": "Cangjie: Profile (cjprof)",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieExtractFunction",
				"title": "Cangjie: Extract Function",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieMoveFile",
				"title": "Cangjie: Move File",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieViewLearnedFixes",
				"title": "Cangjie: View Learned Fixes",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieManageLearnedFixes",
				"title": "Cangjie: Manage Learned Fixes",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieGenerateTestFile",
				"title": "Cangjie: Generate Test File",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.cangjieCleanGeneratedTests",
				"title": "Cangjie: Clean Generated Test Files",
				"category": "Cangjie"
			},
			{
				"command": "njust-ai.triggerInlineCompletion",
				"title": "%command.triggerInlineCompletion.title%",
				"category": "NJUST_AI"
			},
			{
				"command": "njust-ai.inlineCompletionDiagnostics",
				"title": "%command.inlineCompletionDiagnostics.title%",
				"category": "NJUST_AI"
			}
		],
		"menus": {
			"editor/context": [
				{
					"submenu": "njust-ai.contextMenu",
					"group": "1"
				}
			],
			"njust-ai.contextMenu": [
				{
					"command": "njust-ai.addToContext",
					"group": "1_actions@1"
				},
				{
					"command": "njust-ai.explainCode",
					"group": "1_actions@2"
				},
				{
					"command": "njust-ai.improveCode",
					"group": "1_actions@3"
				},
				{
					"command": "njust-ai.cangjieGenerateTestFile",
					"group": "2_cangjie@1",
					"when": "resourceLangId == cangjie || editorLangId == cangjie"
				}
			],
			"explorer/context": [
				{
					"command": "njust-ai.cangjieGenerateTestFile",
					"group": "2_cangjie@1",
					"when": "resourceLangId == cangjie"
				}
			],
			"terminal/context": [
				{
					"submenu": "njust-ai.terminalMenu",
					"group": "2"
				}
			],
			"njust-ai.terminalMenu": [
				{
					"command": "njust-ai.terminalAddToContext",
					"group": "1_actions@1"
				},
				{
					"command": "njust-ai.terminalFixCommand",
					"group": "1_actions@2"
				},
				{
					"command": "njust-ai.terminalExplainCommand",
					"group": "1_actions@3"
				}
			],
			"commandPalette": [
				{
					"command": "njust-ai.latexCompile",
					"when": "editorLangId == latex || editorLangId == tex"
				},
				{
					"command": "njust-ai.cangjieBuild",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieRun",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieTest",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieCheck",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieClean",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieViewLearnedFixes",
					"when": "workspaceFolderCount > 0"
				},
				{
					"command": "njust-ai.cangjieManageLearnedFixes",
					"when": "workspaceFolderCount > 0"
				},
				{
					"command": "njust-ai.cangjieGenerateTestFile",
					"when": "editorLangId == cangjie"
				},
				{
					"command": "njust-ai.cangjieCleanGeneratedTests"
				}
			],
			"view/title": [
				{
					"command": "njust-ai.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == njust-ai.SidebarProvider"
				},
				{
					"command": "njust-ai.runCode",
					"group": "navigation@2",
					"when": "view == njust-ai.SidebarProvider"
				},
				{
					"command": "njust-ai.settingsButtonClicked",
					"group": "navigation@3",
					"when": "view == njust-ai.SidebarProvider"
				},
				{
					"command": "njust-ai.historyButtonClicked",
					"group": "overflow@1",
					"when": "view == njust-ai.SidebarProvider"
				},
				{
					"command": "njust-ai.popoutButtonClicked",
					"group": "overflow@2",
					"when": "view == njust-ai.SidebarProvider"
				}
			],
			"editor/title": [
				{
					"command": "njust-ai.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == njust-ai.TabPanelProvider"
				},
				{
					"command": "njust-ai.runCode",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == njust-ai.TabPanelProvider"
				},
				{
					"command": "njust-ai.settingsButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == njust-ai.TabPanelProvider"
				},
				{
					"command": "njust-ai.historyButtonClicked",
					"group": "overflow@1",
					"when": "activeWebviewPanelId == njust-ai.TabPanelProvider"
				},
				{
					"command": "njust-ai.popoutButtonClicked",
					"group": "overflow@2",
					"when": "activeWebviewPanelId == njust-ai.TabPanelProvider"
				},
				{
					"command": "njust-ai.latexCompile",
					"group": "navigation@9",
					"when": "editorTextFocus && (editorLangId == latex || editorLangId == tex)"
				}
			]
		},
		"keybindings": [
			{
				"command": "njust-ai.addToContext",
				"key": "cmd+k cmd+a",
				"mac": "cmd+k cmd+a",
				"win": "ctrl+k ctrl+a",
				"linux": "ctrl+k ctrl+a",
				"when": "editorTextFocus && editorHasSelection"
			},
			{
				"command": "njust-ai.toggleAutoApprove",
				"key": "cmd+alt+a",
				"mac": "cmd+alt+a",
				"win": "ctrl+alt+a",
				"linux": "ctrl+alt+a"
			},
			{
				"command": "njust-ai.runCode",
				"key": "ctrl+f5",
				"mac": "cmd+f5",
				"win": "ctrl+f5",
				"linux": "ctrl+f5",
				"when": "editorTextFocus"
			},
			{
				"command": "njust-ai.cangjieBuild",
				"key": "ctrl+shift+b",
				"mac": "cmd+shift+b",
				"win": "ctrl+shift+b",
				"linux": "ctrl+shift+b",
				"when": "editorTextFocus && editorLangId == cangjie"
			},
			{
				"command": "njust-ai.cangjieTest",
				"key": "ctrl+shift+t",
				"mac": "cmd+shift+t",
				"win": "ctrl+shift+t",
				"linux": "ctrl+shift+t",
				"when": "editorTextFocus && editorLangId == cangjie"
			},
			{
				"command": "njust-ai.cangjieClean",
				"key": "ctrl+shift+delete",
				"mac": "cmd+shift+delete",
				"win": "ctrl+shift+delete",
				"linux": "ctrl+shift+delete",
				"when": "editorTextFocus && editorLangId == cangjie"
			},
			{
				"command": "njust-ai.triggerInlineCompletion",
				"key": "alt+\\",
				"mac": "alt+\\",
				"win": "alt+\\",
				"linux": "alt+\\",
				"when": "editorTextFocus"
			},
			{
				"command": "njust-ai.openMarkdownPreview",
				"key": "ctrl+q",
				"mac": "ctrl+q",
				"win": "ctrl+q",
				"linux": "ctrl+q",
				"when": "editorTextFocus && editorLangId == markdown"
			}
		],
		"submenus": [
			{
				"id": "njust-ai.contextMenu",
				"label": "%views.contextMenu.label%"
			},
			{
				"id": "njust-ai.terminalMenu",
				"label": "%views.terminalMenu.label%"
			}
		],
		"languageModelTools": [
			{
				"name": "njust_ai_readFile",
				"displayName": "Njust-AI: Read File",
				"modelDescription": "Read the contents of a file in the workspace. Returns the full text content of the specified file.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"path": {
							"type": "string",
							"description": "The path of the file to read, relative to the workspace root"
						}
					},
					"required": [
						"path"
					]
				},
				"tags": [
					"njust-ai-agent",
					"file-operations"
				]
			},
			{
				"name": "njust_ai_editFile",
				"displayName": "Njust-AI: Edit File",
				"modelDescription": "Edit a file by applying a search-and-replace diff patch. Specify the file path and a unified diff.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"path": {
							"type": "string",
							"description": "The path of the file to edit, relative to the workspace root"
						},
						"diff": {
							"type": "string",
							"description": "The unified diff patch to apply to the file"
						}
					},
					"required": [
						"path",
						"diff"
					]
				},
				"tags": [
					"njust-ai-agent",
					"file-operations"
				]
			},
			{
				"name": "njust_ai_executeCommand",
				"displayName": "Njust-AI: Execute Command",
				"modelDescription": "Execute a shell command in the workspace terminal. Returns the command output.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"command": {
							"type": "string",
							"description": "The shell command to execute"
						}
					},
					"required": [
						"command"
					]
				},
				"tags": [
					"njust-ai-agent",
					"terminal"
				]
			},
			{
				"name": "njust_ai_searchFiles",
				"displayName": "Njust-AI: Search Files",
				"modelDescription": "Search for files in the workspace using a regex pattern. Returns matching lines with file paths and line numbers.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"pattern": {
							"type": "string",
							"description": "The regex pattern to search for"
						},
						"path": {
							"type": "string",
							"description": "Optional directory path to limit the search scope"
						}
					},
					"required": [
						"pattern"
					]
				},
				"tags": [
					"njust-ai-agent",
					"search"
				]
			},
			{
				"name": "njust_ai_listFiles",
				"displayName": "Njust-AI: List Files",
				"modelDescription": "List files and directories in the specified path. Returns a tree-like listing.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"path": {
							"type": "string",
							"description": "The directory path to list, relative to the workspace root"
						},
						"recursive": {
							"type": "boolean",
							"description": "Whether to list files recursively"
						}
					},
					"required": [
						"path"
					]
				},
				"tags": [
					"njust-ai-agent",
					"file-operations"
				]
			},
			{
				"name": "njust_ai_codebaseSearch",
				"displayName": "Njust-AI: Codebase Search",
				"modelDescription": "Perform a semantic search across the codebase using natural language queries.",
				"inputSchema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string",
							"description": "The natural language search query"
						}
					},
					"required": [
						"query"
					]
				},
				"tags": [
					"njust-ai-agent",
					"search"
				]
			}
		],
		"chatParticipants": [
			{
				"id": "njust-ai.agent",
				"name": "njust-ai",
				"fullName": "Njust-AI Agent",
				"description": "AI-powered coding agent - read, write, execute, debug",
				"isSticky": true,
				"commands": [
					{
						"name": "code",
						"description": "Write, modify, or refactor code"
					},
					{
						"name": "architect",
						"description": "Plan and design software architecture"
					},
					{
						"name": "ask",
						"description": "Ask questions about the codebase"
					},
					{
						"name": "debug",
						"description": "Debug and diagnose issues"
					},
					{
						"name": "plan",
						"description": "Create an execution plan for a complex task"
					}
				],
				"disambiguation": [
					{
						"category": "njust_ai_coding",
						"description": "The user wants help with coding tasks like writing, editing, debugging, or understanding code in their workspace.",
						"examples": [
							"Help me refactor this function",
							"Write a unit test for this class",
							"Debug why this API call is failing",
							"Explain what this code does",
							"Create a new React component"
						]
					}
				]
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"njust-ai.memrl.embeddingApiKey": {
					"type": "string",
					"default": "",
					"markdownDescription": "API key for the MemRL memory embedding model (OpenAI-compatible). If empty, falls back to the `MEMRL_EMBED_API_KEY` environment variable; if that is also empty, memory retrieval is disabled (tasks still run)."
				},
				"njust-ai.memrl.embeddingBaseUrl": {
					"type": "string",
					"default": "",
					"markdownDescription": "Base URL for the MemRL memory embedding API (OpenAI-compatible). Empty = use `MEMRL_EMBED_BASE_URL` env var, else default `https://api.siliconflow.cn/v1`."
				},
				"njust-ai.memrl.embeddingModel": {
					"type": "string",
					"default": "",
					"markdownDescription": "Model id for MemRL memory embeddings. Empty = use `MEMRL_EMBED_MODEL` env var, else default `BAAI/bge-m3`. ⚠️ Changing the model invalidates previously stored memory vectors (they are auto-rebuilt on next run)."
				},
				"njust-ai.allowedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"git log",
						"git diff",
						"git show"
					],
					"description": "%commands.allowedCommands.description%"
				},
				"njust-ai.deniedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.deniedCommands.description%"
				},
				"njust-ai.saveAllBeforeExecuteCommand": {
					"type": "boolean",
					"default": true,
					"description": "%commands.saveAllBeforeExecuteCommand.description%"
				},
				"njust-ai.commandExecutionTimeout": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 600,
					"description": "%commands.commandExecutionTimeout.description%"
				},
				"njust-ai.commandTimeoutAllowlist": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.commandTimeoutAllowlist.description%"
				},
				"njust-ai.preventCompletionWithOpenTodos": {
					"type": "boolean",
					"default": false,
					"description": "%commands.preventCompletionWithOpenTodos.description%"
				},
				"njust-ai.enableWebSearch": {
					"type": "boolean",
					"default": false,
					"description": "Enable web search tool for AI agent to fetch real-time information from the internet"
				},
				"njust-ai.enableStreamingToolExecution": {
					"type": "boolean",
					"default": true,
					"description": "Enable eager streaming execution for auto-approved concurrency-safe tools. Disable to fully fallback to post-stream tool execution behavior."
				},
				"njust-ai.webSearchApiKey": {
					"type": "string",
					"default": "",
					"description": "API key for web search provider (Tavily). Get a free key at https://tavily.com"
				},
				"njust-ai.vsCodeLmModelSelector": {
					"type": "object",
					"properties": {
						"vendor": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.vendor.description%"
						},
						"family": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.family.description%"
						}
					},
					"description": "%settings.vsCodeLmModelSelector.description%"
				},
				"njust-ai.customStoragePath": {
					"type": "string",
					"default": "",
					"description": "%settings.customStoragePath.description%"
				},
				"njust-ai.enableCodeActions": {
					"type": "boolean",
					"default": true,
					"description": "%settings.enableCodeActions.description%"
				},
				"njust-ai.autoImportSettingsPath": {
					"type": "string",
					"default": "",
					"description": "%settings.autoImportSettingsPath.description%"
				},
				"njust-ai.maximumIndexedFilesForFileSearch": {
					"type": "number",
					"default": 10000,
					"minimum": 5000,
					"maximum": 500000,
					"description": "%settings.maximumIndexedFilesForFileSearch.description%"
				},
				"njust-ai.useAgentRules": {
					"type": "boolean",
					"default": true,
					"description": "%settings.useAgentRules.description%"
				},
				"njust-ai.apiRequestTimeout": {
					"type": "number",
					"default": 300,
					"minimum": 0,
					"maximum": 3600,
					"description": "%settings.apiRequestTimeout.description%"
				},
				"njust-ai.newTaskRequireTodos": {
					"type": "boolean",
					"default": false,
					"description": "%settings.newTaskRequireTodos.description%"
				},
				"njust-ai.codeIndex.embeddingBatchSize": {
					"type": "number",
					"default": 60,
					"minimum": 1,
					"maximum": 200,
					"description": "%settings.codeIndex.embeddingBatchSize.description%"
				},
				"njust-ai.cangjieContext.l3CacheTtlMs": {
					"type": "number",
					"default": 12000,
					"minimum": 1000,
					"maximum": 120000,
					"description": "TTL (ms) for the Cangjie Dev L3 full-context cache (mtime-based key). Increase for fewer rebuilds; decrease for fresher prompts."
				},
				"njust-ai.cangjieContextTokenBudget": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 12000,
					"markdownDescription": "Override the Cangjie Dev dynamic context token budget. When set to a positive value, this takes priority over the automatic model-scaled budget. When 0 (default), the budget is derived from the model's context window (e.g. 2400 for 16k, 4800 for 128k, 6000 for 200k+)."
				},
				"njust-ai.latex.engine": {
					"type": "string",
					"enum": [
						"latexmk",
						"pdflatex"
					],
					"default": "latexmk",
					"description": "Local LaTeX compiler driver. Uses TeX Live / MiKTeX on your machine (not Overleaf cloud). latexmk runs multiple passes for references; pdflatex runs a single pass."
				},
				"njust-ai.latex.latexmkPath": {
					"type": "string",
					"default": "",
					"description": "Path to latexmk (e.g. ...\\\\MiKTeX\\\\miktex\\\\bin\\\\x64\\\\latexmk.exe on Windows). Empty: try PATH, then common MiKTeX/TeX Live locations on Windows."
				},
				"njust-ai.latex.pdflatexPath": {
					"type": "string",
					"default": "",
					"description": "Path to pdflatex. Empty: try PATH, then common MiKTeX/TeX Live locations on Windows."
				},
				"njust-ai.latex.openPdfAfterSuccess": {
					"type": "boolean",
					"default": true,
					"description": "Open the generated PDF in VS Code after a successful compile."
				},
				"njust-ai.latex.extraArgs": {
					"type": "array",
					"default": [],
					"items": {
						"type": "string"
					},
					"description": "Extra arguments passed to latexmk or pdflatex (after built-in flags)."
				},
				"njust-ai.cangjieLsp.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable the Cangjie Language Server (LSP)."
				},
				"njust-ai.cangjieLsp.serverPath": {
					"type": "string",
					"default": "",
					"description": "Path to the Cangjie LSP server executable (LSPServer / LSPServer.exe). Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieLsp.enableLog": {
					"type": "boolean",
					"default": false,
					"description": "Enable Cangjie LSP server logging."
				},
				"njust-ai.cangjieLsp.logPath": {
					"type": "string",
					"default": "",
					"description": "Custom log path for the Cangjie LSP server. If empty, logs are written to the server's default location."
				},
				"njust-ai.cangjieLsp.disableAutoImport": {
					"type": "boolean",
					"default": false,
					"description": "Disable auto-import in Cangjie code completion."
				},
				"njust-ai.cangjieLsp.suppressLspErrorsAfterCjpmSuccessMs": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 30000,
					"description": "After cjpm build succeeds, drop incoming LSP Error diagnostics for this many ms per project root (0 = off). Use ~1500–3000 if the server immediately republishes stale errors."
				},
				"njust-ai.cangjieLsp.cjcPath": {
					"type": "string",
					"default": "",
					"description": "Path to the Cangjie compiler (cjc) for AST analysis. Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieTools.cjfmtPath": {
					"type": "string",
					"default": "",
					"description": "Path to the cjfmt formatter executable. Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieTools.cjlintPath": {
					"type": "string",
					"default": "",
					"description": "Path to the cjlint static analysis tool. Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieTools.runLintAfterBuild": {
					"type": "boolean",
					"default": true,
					"description": "After a successful cjpm build from the save pipeline, run cjlint on the saved file so diagnostics stay aligned with compile."
				},
				"njust-ai.cangjieTools.cjpmPath": {
					"type": "string",
					"default": "",
					"description": "Path to the cjpm project manager. Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieTools.cjprofPath": {
					"type": "string",
					"default": "",
					"description": "Path to the cjprof profiler executable. Leave empty to auto-detect from CANGJIE_HOME or PATH."
				},
				"njust-ai.cangjieTools.hotReload": {
					"type": "boolean",
					"default": false,
					"description": "During a Cangjie debug session, re-run cjpm build on .cj save and send a DAP hotReload request (requires cjdb/SDK support)."
				},
				"njust-ai.cangjieTools.useCjcAstForIndex": {
					"type": "boolean",
					"default": false,
					"description": "Use `cjc --dump-ast` for richer symbol indexing when cjc is available. Falls back to the regex parser on failure. Requires Cangjie SDK."
				},
				"njust-ai.matlabTools.matlabPath": {
					"type": "string",
					"default": "",
					"description": "MATLAB 可执行文件完整路径（matlab / matlab.exe；留空则自动检测 PATH 与常见安装目录）"
				},
				"njust-ai.matlabTools.octavePath": {
					"type": "string",
					"default": "",
					"description": "Octave 可执行文件完整路径（留空则自动检测 PATH；未安装 MATLAB 时使用）"
				},
				"njust-ai.cloudAgent.serverUrl": {
					"type": "string",
					"default": "",
					"description": "[已废弃] 请使用 Cloud Agent Profile 管理连接配置。此设置仅在未配置 Profile 时作为后备。Cloud Agent REST base URL (GET /health, POST /v1/run)."
				},
				"njust-ai.cloudAgent.deviceToken": {
					"type": "string",
					"default": "",
					"description": "Auto-generated device token for Cloud Agent authentication. Do not modify manually."
				},
				"njust-ai.cloudAgent.apiKey": {
					"type": "string",
					"default": "",
					"description": "[已废弃] 请使用 Cloud Agent Profile 管理 API Key。此设置仅在未配置 Profile 时作为后备。X-API-Key for Cloud Agent (must match server CLOUD_AGENT_MOCK_API_KEY)."
				},
				"njust-ai.cloudAgent.requestTimeoutMs": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 3600000,
					"description": "Timeout in milliseconds for each Cloud Agent HTTP request (health and /v1/run). 0 means no timeout."
				},
				"njust-ai.cloudAgent.applyRemoteWorkspaceOps": {
					"type": "boolean",
					"default": true,
					"description": "When true (default), apply structured workspace_ops (write_file / apply_diff) from Cloud Agent POST /v1/run responses inside the current workspace. Disable if you do not trust the cloud service; paths are restricted to the workspace."
				},
				"njust-ai.cloudAgent.confirmRemoteWorkspaceOps": {
					"type": "boolean",
					"default": true,
					"description": "When applyRemoteWorkspaceOps is enabled, show a tool-style approval UI for each operation before writing. When false, all operations run in one batch without per-step confirmation."
				},
				"njust-ai.cloudAgent.deferredProtocol": {
					"type": "boolean",
					"default": true,
					"description": "Use the deferred execution protocol (POST /v1/run/deferred/start → local tool execution → POST /v1/run/deferred/resume → loop until done). When false, falls back to single-shot POST /v1/run. The deferred protocol allows the server to request local tool calls (read_file, write_file, execute_command, etc.) and iterate until the task completes."
				},
				"njust-ai.cloudAgent.compileLoop.enabled": {
					"type": "boolean",
					"default": true,
					"description": "After Cloud Agent writes code via workspace_ops, call POST /v1/run/compile on the server to compile. If compilation fails, send errors back to the agent for automatic correction and loop until success or maxRetries. Applies to both legacy (/v1/run) and default deferred (/v1/run/deferred/start) paths."
				},
				"njust-ai.cloudAgent.compileLoop.maxRetries": {
					"type": "number",
					"default": 3,
					"minimum": 1,
					"maximum": 10,
					"description": "Maximum compile-fix iterations in the compile feedback loop. Each iteration: compile → read errors → agent fixes → re-compile."
				},
				"njust-ai.mcpServer.enabled": {
					"type": "boolean",
					"default": false,
					"description": "Enable the built-in MCP Tools Server, allowing external agents to call internal tools (read/write files, execute commands, search, etc.) via the MCP protocol over HTTP."
				},
				"njust-ai.mcpServer.port": {
					"type": "number",
					"default": 3100,
					"minimum": 1024,
					"maximum": 65535,
					"description": "Port number for the MCP Tools Server (requires restart after change)."
				},
				"njust-ai.mcpServer.bindAddress": {
					"type": "string",
					"default": "127.0.0.1",
					"enum": [
						"127.0.0.1",
						"0.0.0.0"
					],
					"enumDescriptions": [
						"Localhost only — accessible from this machine only (safe default)",
						"All interfaces — accessible from remote machines (requires authToken)"
					],
					"description": "Network address for the MCP Tools Server to bind to. Use '0.0.0.0' to allow remote agents (cloud-deployed) to connect. Requires authToken when set to '0.0.0.0'. Requires restart after change."
				},
				"njust-ai.mcpServer.authToken": {
					"type": "string",
					"default": "",
					"description": "Bearer token for authenticating MCP Tools Server requests. REQUIRED when bindAddress is '0.0.0.0'. Leave empty to disable authentication (only for local-only access)."
				},
				"njust-ai.debug": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debug.description%"
				},
				"njust-ai.debugProxy.enabled": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.enabled.description%",
					"markdownDescription": "%settings.debugProxy.enabled.description%"
				},
				"njust-ai.debugProxy.serverUrl": {
					"type": "string",
					"default": "http://127.0.0.1:8888",
					"description": "%settings.debugProxy.serverUrl.description%",
					"markdownDescription": "%settings.debugProxy.serverUrl.description%"
				},
				"njust-ai.debugProxy.tlsInsecure": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.tlsInsecure.description%",
					"markdownDescription": "%settings.debugProxy.tlsInsecure.description%"
				},
				"njust-ai.inlineCompletion.enabled": {
					"type": "boolean",
					"default": true,
